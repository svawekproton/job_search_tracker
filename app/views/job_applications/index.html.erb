<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="fw-bold h2">Application Pipeline</h1>
  <%= link_to new_job_application_path, class: "btn btn-primary px-4 shadow-sm" do %>
    <i class="bi bi-plus-lg me-2"></i>New Application
  <% end %>
</div>

<div class="row mb-4">
  <div class="col-md-6">
    <%= form_with url: job_applications_path, method: :get, class: "input-group shadow-sm" do |f| %>
      <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
      <%= f.text_field :query, value: params[:query], class: "form-control border-start-0 border-end-0 ps-0", placeholder: "Search companies, positions..." %>
      <% if params[:query].present? %>
        <%= link_to job_applications_path(status: params[:status]), class: "btn btn-white border-start-0 border-end-0 text-muted" do %>
          <i class="bi bi-x-circle"></i>
        <% end %>
      <% end %>
      <%= f.submit "Search", class: "btn btn-primary d-none" %>
      <%= f.hidden_field :status, value: params[:status] if params[:status].present? %>
    <% end %>
  </div>
  <div class="col-md-6 text-md-end mt-3 mt-md-0">
    <div class="btn-group shadow-sm" role="group">
      <%= link_to "All", job_applications_path(query: params[:query]), class: "btn btn-white #{'active fw-bold' if params[:status].blank?}" %>
      <% JobApplication.statuses.keys.each do |status| %>
        <%= link_to status.humanize, job_applications_path(status: status, query: params[:query]), 
            class: "btn btn-white #{'active fw-bold' if params[:status] == status}" %>
      <% end %>
    </div>
  </div>
</div>

<div id="job_applications">
  <% @job_applications.each do |job_application| %>
    <%= render job_application %>
  <% end %>
</div>
