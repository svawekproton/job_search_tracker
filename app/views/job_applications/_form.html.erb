<%= form_with(model: job_application) do |form| %>
  <% if job_application.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(job_application.errors.count, "error") %> prohibited this job_application from being saved:</h2>

      <ul>
        <% job_application.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :company_name, style: "display: block" %>
    <%= form.text_field :company_name %>
  </div>

  <div>
    <%= form.label :position, style: "display: block" %>
    <%= form.text_field :position %>
  </div>

  <div class="mb-3">
    <%= form.label :status, class: "form-label" %>
    <%= form.select :status, JobApplication.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= form.label :applied_at, class: "form-label" %>
    <%= form.date_field :applied_at, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :cv, "CV", class: "form-label" %>
    <%= form.file_field :cv, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :cover_letter, class: "form-label" %>
    <%= form.file_field :cover_letter, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :url, class: "form-label" %>
    <%= form.text_field :url, class: "form-control" %>
  </div>

  <div>
    <%= form.label :location, style: "display: block" %>
    <%= form.text_field :location %>
  </div>

  <div>
    <%= form.label :description, style: "display: block" %>
    <%= form.textarea :description %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
