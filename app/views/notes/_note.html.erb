<div id="<%= dom_id note %>" class="card border-0 shadow-sm mb-3">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <span class="badge bg-light text-muted border rounded-pill">
        <i class="bi bi-sticky me-1"></i><%= note.category %>
      </span>
      <small class="text-muted"><%= time_ago_in_words(note.created_at) %> ago</small>
    </div>
    <div class="trix-content small px-1">
      <%= note.content %>
    </div>
  </div>
</div>
