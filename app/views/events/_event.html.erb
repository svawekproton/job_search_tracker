<div id="<%= dom_id event %>" class="card border-0 shadow-sm mb-3">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <h6 class="fw-bold mb-0">
        <i class="bi bi-calendar-event text-primary me-2"></i><%= event.title %>
      </h6>
      <span class="badge bg-primary-subtle text-primary border-primary-subtle rounded-pill"><%= event.event_type.humanize %></span>
    </div>
    <div class="text-muted small mb-2">
      <i class="bi bi-clock me-1"></i><%= event.scheduled_at.strftime("%B %d, %Y at %I:%M %p") %>
    </div>
    <% if event.notes.present? %>
      <div class="bg-light p-3 rounded small text-muted border-start border-4 border-primary-subtle">
        <%= event.notes %>
      </div>
    <% end %>
  </div>
</div>
